NODE_ENV=development
PORT=4000

# Comma-separated API keys accepted by this gateway.
MMT_API_KEYS=dev_mmt_key

# LiteLLM gateway
LITELLM_BASE_URL=http://localhost:4001
LITELLM_API_KEY=dev_litellm_master_key
LITELLM_MODEL=mmt-fast-lite

# OpenRouter is consumed by LiteLLM, not directly by the NestJS API.
OPENROUTER_API_KEY=
OR_SITE_URL=https://github.com/nwangasam/mmt
OR_APP_NAME=MMT

# Search
# Local dev defaults to SearXNG. Use SEARCH_PROVIDER=brave in production.
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8080
BRAVE_SEARCH_API_KEY=
SEARCH_RESULT_LIMIT=6

# Infra
DATABASE_URL=postgresql://mmt:mmt@localhost:5432/mmt
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=2592000
